# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "openai" | "gemini"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Gemini (alternative provider)
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-1.5-pro

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Must be prefixed with NEXT_PUBLIC_ to be exposed to the browser
NEXT_PUBLIC_API_URL=http://localhost:3001
