{
  "name": "@csv-crm/api",
  "version": "0.0.1",
  "private": true,
  "description": "Node.js / Express backend for the AI-powered CSV CRM Importer",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@csv-crm/shared": "workspace:*",
    "@google/generative-ai": "^0.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.73.0",
    "papaparse": "^5.4.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.3.14",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
