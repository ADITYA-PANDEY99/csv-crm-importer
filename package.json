{
  "name": "csv-crm-importer",
  "version": "0.0.1",
  "private": true,
  "description": "AI-powered CSV to CRM record importer — monorepo",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "dev:web": "pnpm --filter @csv-crm/web dev",
    "dev:api": "pnpm --filter @csv-crm/api dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
